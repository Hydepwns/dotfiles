{{- $name := promptStringOnce . "name" "Display name" -}}
{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $github := promptStringOnce . "github" "GitHub username" -}}
{{- $age_recipient := promptStringOnce . "age_recipient" "Age public key (press Enter to skip, generate later with: make setup-age)" -}}

# Generated from .chezmoi.toml.tmpl -- edit the template, not this file
{{ if $age_recipient -}}
encryption = "age"
{{ end -}}
sourceDir = "{{ .chezmoi.workingTree }}/home"

[data]
# User identity (prompted on first chezmoi init)
name = {{ $name | quote }}
email = {{ $email | quote }}
github = {{ $github | quote }}
{{ if $age_recipient -}}
age_recipient = {{ $age_recipient | quote }}
{{ end -}}

# Shell configuration
gpg_signing_key = "1938C94528268692"
oh_my_zsh_theme = "robbyrussell"
oh_my_zsh_plugins = "git"
starship = true
personal = true

# Tool configurations
rust = true
ohmyzsh = true
mise = true
elixir = true
erlang = true
lua = true
direnv = true
devenv = false
nix = true
llvm = false
postgres = false
psql = false
foundry = false
huff = false
solana = false
orbstack = true
tailscale = true
onepassword = true
aws = true
infisical = true
paperwm = true
raycast = true
takopi = true
work = false

# Platform-specific
{{- if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}
brewPrefix = "/opt/homebrew"
{{- else }}
brewPrefix = "/usr/local"
{{- end }}

# Synthwave84 Theme
[data.theme]
name = "Synthwave84"
bg = "#262335"
bg_dark = "#241b2f"
bg_light = "#2a2139"
fg = "#ffffff"
fg_dim = "#848bbd"
accent = "#ff7edb"
accent2 = "#36f9f6"
cursor = "#ff7edb"
selection_bg = "#ff7edb"
selection_fg = "#241b2f"
border = "#495495"
black = "#241b2f"
red = "#fe4450"
green = "#72f1b8"
yellow = "#fede5d"
blue = "#03edf9"
magenta = "#ff7edb"
cyan = "#36f9f6"
white = "#ffffff"
bright_black = "#495495"
bright_red = "#fe4450"
bright_green = "#72f1b8"
bright_yellow = "#fede5d"
bright_blue = "#03edf9"
bright_magenta = "#ff7edb"
bright_cyan = "#36f9f6"
bright_white = "#ffffff"

[git]
autoCommit = true
autoPush = false

{{ if $age_recipient -}}
[age]
# To use 1Password-backed decryption (no key on disk), create ~/.config/chezmoi/age-op-decrypt.sh
# Otherwise, use a plaintext key file: identity = "~/.config/chezmoi/age_key.txt"
{{ if stat (joinPath .chezmoi.homeDir ".config/chezmoi/age-op-decrypt.sh") -}}
command = "~/.config/chezmoi/age-op-decrypt.sh"
{{ else -}}
identity = "~/.config/chezmoi/age_key.txt"
{{ end -}}
recipient = {{ $age_recipient | quote }}
{{ end -}}

[template]
options = ["missingkey=error"]

[diff]
pager = ""

[status]
pathStyle = "relative"
